# WebHarvest Configuration
# Copy to .env and customize

# ── Fetch settings ───────────────────────────────────────
WEBHARVEST_DEFAULT_TIMEOUT_MS=30000
WEBHARVEST_MAX_CONCURRENT=5
WEBHARVEST_RATE_LIMIT_RPM=60

# ── Proxy (JSON array of proxy URLs) ────────────────────
# WEBHARVEST_PROXY_URLS=["http://proxy1:8080","http://proxy2:8080"]

# ── Cache ────────────────────────────────────────────────
WEBHARVEST_CACHE_DIR=.webharvest_cache
WEBHARVEST_CACHE_TTL=3600

# ── Browser (requires: pip install webharvest[browser]) ──
WEBHARVEST_USE_BROWSER=false
WEBHARVEST_BROWSER_HEADLESS=true

# ── API server ───────────────────────────────────────────
WEBHARVEST_API_HOST=0.0.0.0
WEBHARVEST_API_PORT=8787
